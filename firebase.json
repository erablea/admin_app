{
	"hosting": {
		"public": "build/web",
		"ignore": [
			"firebase.json",
			"**/.*",
			"**/node_modules/**"
		],
		"headers": [
			{
				"source": "**/*.@(jpg|jpeg|gif|png)",
				"headers": [
					{
						"key": "Access-Control-Allow-Origin",
						"value": "*"
					},
					{
						"key": "Access-Control-Allow-Methods",
						"value": "GET, HEAD, OPTIONS"
					},
					{
						"key": "Access-Control-Allow-Headers",
						"value": "Origin, X-Requested-With, Content-Type, Accept"
					}
				]
			}
		]
	}
}